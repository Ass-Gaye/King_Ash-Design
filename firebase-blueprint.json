{
  "entities": {
    "WebsiteSettings": {
      "title": "Website Settings",
      "description": "General settings and content for the website",
      "type": "object",
      "properties": {
        "heroTitle": { "type": "string" },
        "heroTagline": { "type": "string" },
        "aboutStory": { "type": "string" },
        "aboutMission": { "type": "string" },
        "aboutVision": { "type": "string" },
        "phoneNumbers": { "type": "array" },
        "emails": { "type": "array" },
        "location": { "type": "string" },
        "whatsappNumber": { "type": "string" },
        "facebookUrl": { "type": "string" },
        "instagramUrl": { "type": "string" },
        "tiktokUrl": { "type": "string" }
      },
      "required": ["heroTitle", "heroTagline"]
    },
    "GalleryItem": {
      "title": "Gallery Item",
      "description": "A garment showcase item in the gallery",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "category": { "type": "string" },
        "imageUrl": { "type": "string" },
        "featured": { "type": "boolean" },
        "createdAt": { "type": "string" }
      },
      "required": ["id", "title", "category", "imageUrl", "createdAt"]
    },
    "Testimonial": {
      "title": "Testimonial",
      "description": "A client review/testimonial",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "role": { "type": "string" },
        "content": { "type": "string" },
        "rating": { "type": "integer" },
        "createdAt": { "type": "string" }
      },
      "required": ["id", "name", "content", "rating", "createdAt"]
    },
    "InquiryMessage": {
      "title": "Inquiry Message",
      "description": "An inquiry message from a customer",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string" },
        "phone": { "type": "string" },
        "subject": { "type": "string" },
        "message": { "type": "string" },
        "status": { "type": "string" },
        "createdAt": { "type": "string" }
      },
      "required": ["id", "name", "email", "message", "status", "createdAt"]
    },
    "CustomOrder": {
      "title": "Custom Order",
      "description": "A booking/order for a custom garment tailoring",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "trackingId": { "type": "string" },
        "fullName": { "type": "string" },
        "email": { "type": "string" },
        "phoneNumber": { "type": "string" },
        "deliveryAddress": { "type": "string" },
        "garmentType": { "type": "string" },
        "gender": { "type": "string" },
        "fabricPreference": { "type": "string" },
        "sizeType": { "type": "string" },
        "chest": { "type": "string" },
        "waist": { "type": "string" },
        "hips": { "type": "string" },
        "shoulder": { "type": "string" },
        "sleeves": { "type": "string" },
        "length": { "type": "string" },
        "customSizeNotes": { "type": "string" },
        "eventDate": { "type": "string" },
        "preferredDeliveryDate": { "type": "string" },
        "budgetRange": { "type": "string" },
        "additionalNotes": { "type": "string" },
        "attachments": { "type": "array" },
        "status": { "type": "string" },
        "createdAt": { "type": "string" }
      },
      "required": ["id", "trackingId", "fullName", "email", "phoneNumber", "garmentType", "status", "createdAt"]
    },
    "AdminUser": {
      "title": "Admin User",
      "description": "Administrative user credentials",
      "type": "object",
      "properties": {
        "email": { "type": "string" },
        "passwordHash": { "type": "string" }
      },
      "required": ["email", "passwordHash"]
    }
  },
  "firestore": {
    "settings": {
      "schema": { "$ref": "#/entities/WebsiteSettings" },
      "description": "Global website settings and content"
    },
    "gallery": {
      "schema": { "$ref": "#/entities/GalleryItem" },
      "description": "Tailoring showcase items"
    },
    "testimonials": {
      "schema": { "$ref": "#/entities/Testimonial" },
      "description": "Customer reviews"
    },
    "inquiries": {
      "schema": { "$ref": "#/entities/InquiryMessage" },
      "description": "Contact messages"
    },
    "orders": {
      "schema": { "$ref": "#/entities/CustomOrder" },
      "description": "Garment booking and order entries"
    },
    "admin": {
      "schema": { "$ref": "#/entities/AdminUser" },
      "description": "Admin configuration and credentials"
    }
  }
}
